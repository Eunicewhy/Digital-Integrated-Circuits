.meas TRAN TpLH_Sum_011to010 TRIG V(Cin) VAL=0.35 FALL=8 TARG V(Sum) VAL=0.35 RISE=8
.meas TRAN TpHL_Sum_010to101 TRIG V(Cin) VAL=0.35 RISE=9 TARG V(Sum) VAL=0.35 FALL=8
.meas TRAN TpLH_Sum_101to010 TRIG V(Cin) VAL=0.35 FALL=9 TARG V(Sum) VAL=0.35 RISE=9
.meas TRAN TpHL_Sum_010to110 TRIG V(A) VAL=0.35 RISE=11 TARG V(Sum) VAL=0.35 FALL=9
.meas TRAN TpLH_Sum_110to010 TRIG V(A) VAL=0.35 FALL=11 TARG V(Sum) VAL=0.35 RISE=10
.meas TRAN TpHL_Sum_111to011 TRIG V(A) VAL=0.35 FALL=12 TARG V(Sum) VAL=0.35 FALL=10
