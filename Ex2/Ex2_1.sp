*ex2.1*
.include '7nm_TT.pm'
.temp 25
.global VDD GND

.param Vdd = 0.7v 

VDD VDD GND Vdd
.include 'asap7_75t_R_24.cdl'
.include 'asap7sc7p5t_INVBUF_RVT.sp'

* Input Buffer (Smallest Inverter)
.subckt inv_buffer vin vo
    XSINV0 GND VDD vin vx INVxp33_ASAP7_75t_R
    XSINV1 GND VDD vx  vo INVxp33_ASAP7_75t_R
.ends

* PINs connected to buffer
XBUF0 A   A_buff  inv_buffer
XBUF1 B   B_buff  inv_buffer
XBUF2 Cin C_buff  inv_buffer

* Sum
XRO0 A_buff B_buff VDD GND Y_xor XOR2x2_ASAP7_75t_R
XRO1 Y_xor  C_buff VDD GND Sum   XOR2x2_ASAP7_75t_R

* Co
XMAJ0 A_buff B_buff C_buff VDD GND Co MAJx3_ASAP7_75t_R

C0 Sum GND 5f
C1 Co  GND 5f

* Input Vector
.VEC 'Ex2_1.vec'

*main
*V_A     A    0 PULSE(0 Vdd 4ns 1ps 1ps 4ns 8ns)
*V_B     B    0 PULSE(0 Vdd 2ns 1ps 1ps 2ns 4ns)
*V_Cin   Cin  0 PULSE(0 Vdd 1ns 1ps 1ps 1ns 2ns)

.tran 0.01n 15n
** Measurement
* Sum
.meas TRAN TpLH_Sum_000to001 TRIG V(Cin) VAL=0.35 RISE=1 TARG V(Sum) VAL=0.35 RISE=1
.meas TRAN TpHL_Sum_001to000 TRIG V(Cin) VAL=0.35 FALL=1 TARG V(Sum) VAL=0.35 FALL=1
.meas TRAN TpLH_Sum_000to010 TRIG V(B) VAL=0.35 RISE=1 TARG V(Sum) VAL=0.35 RISE=2
.meas TRAN TpHL_Sum_010to000 TRIG V(B) VAL=0.35 FALL=1 TARG V(Sum) VAL=0.35 FALL=2
.meas TRAN TpLH_Sum_000to100 TRIG V(A) VAL=0.35 RISE=1 TARG V(Sum) VAL=0.35 RISE=3
.meas TRAN TpHL_Sum_100to000 TRIG V(A) VAL=0.35 FALL=1 TARG V(Sum) VAL=0.35 FALL=3
.meas TRAN TpLH_Sum_000to111 TRIG V(Cin) VAL=0.35 RISE=4 TARG V(Sum) VAL=0.35 RISE=4
.meas TRAN TpHL_Sum_001to011 TRIG V(B) VAL=0.35 RISE=6 TARG V(Sum) VAL=0.35 FALL=4
.meas TRAN TpLH_Sum_011to001 TRIG V(B) VAL=0.35 FALL=6 TARG V(Sum) VAL=0.35 RISE=5
